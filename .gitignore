# 1️⃣ Make sure SSH agent is running and key is loaded
eval $(ssh-agent -s)
ssh-add ~/.ssh/id_ed25519

# 2️⃣ Overwrite the conflicted .gitignore with your local version
# (this removes all conflict markers automatically)
cp .gitignore .gitignore.bak       # backup just in case
sed -i '/^<<<<<<<\|^=======\|^>>>>>>>/d' .gitignore

# 3️⃣ Mark it as resolved
git add .gitignore

# 4️⃣ Continue the rebase
git rebase --continue || echo "Rebase complete or no more conflicts"

# 5️⃣ Push your main branch to GitHub via SSH
git push -u origin main
